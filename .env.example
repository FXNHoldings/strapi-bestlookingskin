# Strapi backend
NEXT_PUBLIC_STRAPI_URL=https://cms.fxnstudio.com
STRAPI_API_TOKEN=
# Token with CREATE permission on commerce-price-alert (price-drop alerts).
# Falls back to STRAPI_API_TOKEN if unset. See PRICE_ALERTS.md.
STRAPI_WRITE_TOKEN=

# Public site URL (used for canonicals, sitemap, RSS, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.bestlooking.skin

# Default Amazon Associates tag — appended to amzn.to / amazon.* links missing a tag
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=

# Contact form email delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=hello@bestlooking.skin
CONTACT_FROM_EMAIL=
